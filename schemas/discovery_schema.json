{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://specwatch.internal/schemas/discovery_schema.json",
  "title": "SpecWatch Discovery Schema",
  "description": "Results from Tavily API search for vendor documentation sources",
  "type": "object",
  "required": ["vendor", "api", "discovered_at", "sources"],
  "properties": {
    "vendor": {
      "type": "string",
      "description": "Vendor identifier (lowercase, no spaces)",
      "examples": ["stripe", "twilio", "openai"]
    },
    "api": {
      "type": "string",
      "description": "Display name of the API",
      "examples": ["Stripe", "Twilio", "OpenAI"]
    },
    "discovered_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp when discovery occurred",
      "examples": ["2026-03-29T20:27:50Z"]
    },
    "sources": {
      "type": "object",
      "description": "Discovered documentation sources (categorized by type)",
      "properties": {
        "openapi": {
          "type": "string",
          "format": "uri",
          "description": "URL to OpenAPI specification (YAML/JSON)",
          "examples": [
            "https://github.com/stripe/openapi",
            "https://raw.githubusercontent.com/stripe/openapi/master/openapi/spec3.yaml"
          ]
        },
        "docs": {
          "type": "string",
          "format": "uri",
          "description": "URL to official API documentation",
          "examples": [
            "https://stripe.com/docs/api",
            "https://docs.stripe.com/apis"
          ]
        },
        "changelog": {
          "type": "string",
          "format": "uri",
          "description": "URL to API changelog/release notes",
          "examples": [
            "https://stripe.com/docs/upgrades",
            "https://docs.stripe.com/changelog"
          ]
        },
        "sdk_repo": {
          "type": "string",
          "format": "uri",
          "description": "URL to official SDK repository",
          "examples": [
            "https://github.com/stripe/stripe-python",
            "https://github.com/twilio/twilio-node"
          ]
        }
      }
    },
    "tavily_metadata": {
      "type": "object",
      "description": "Metadata from Tavily search results",
      "properties": {
        "queries_executed": {
          "type": "integer",
          "description": "Number of Tavily queries executed",
          "examples": [3]
        },
        "total_results": {
          "type": "integer",
          "description": "Total number of results returned",
          "examples": [15]
        },
        "confidence_score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Average confidence score from Tavily",
          "examples": [0.95]
        }
      }
    },
    "fallback_used": {
      "type": "boolean",
      "description": "Whether manual vendor_specs.json was used as fallback",
      "default": false
    }
  },
  "examples": [
    {
      "vendor": "stripe",
      "api": "Stripe",
      "discovered_at": "2026-03-29T20:27:50Z",
      "sources": {
        "openapi": "https://github.com/stripe/openapi",
        "docs": "https://docs.stripe.com/apis",
        "changelog": "https://docs.stripe.com/changelog"
      },
      "tavily_metadata": {
        "queries_executed": 3,
        "total_results": 15,
        "confidence_score": 0.95
      },
      "fallback_used": false
    }
  ]
}
